generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model CoinsList {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  data           Json?
  titleSlug      String      @unique
  emojiSlug      String      @unique
  emojis         String[]
  status         CoinStatus? @default(PENDING)
  creatorAddress String?
  createdAt      DateTime    @default(now())
  meta           Meta
}

enum CoinStatus {
  PENDING
  APPROVED
  REJECTED
  LAUNCHED
}

type Meta {
  title                String
  description          String
  imageURL             String
  nonProfitName        String?
  nonProfitDescription String?
  nonProfitImageURL    String?
  nonProfitLink        String?
}

model Config {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  lastIndex Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
